# AmoxcAILab — variables de entorno
# Copia este archivo como .env y define los valores reales.
# NUNCA subas .env al repositorio — está en .gitignore.

# Contraseña para el rol amoxcailab de PostgreSQL.
# Se usa en htr_db_init para crear/actualizar el rol,
# y en todos los scripts como PGPASSWORD.
HTR_PGPASSWORD=cambia_esto_por_una_contraseña_segura

# Sobreescrituras opcionales (si no se definen, se usan los defaults del flake)
# HTR_PGDATA=$HOME/.local/share/htr-pipeline/pgdata
# HTR_PGRUN=$HOME/.local/share/htr-pipeline/run
# HTR_PGPORT=5433
# HTR_PGDB=htr_pipeline
# HTR_PGUSER=$USER
# HTR_MODELS_DIR=$(pwd)/data_ingestion/models
# HTR_COLLABORATOR_ID=
